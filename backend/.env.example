# ─ Local development ────────────────────────────────────────────────────────
PORT=5001

# Option A: full connection string (used by Render)
# DATABASE_URL=postgresql://user:password@host:5432/task_tracker

# Option B: individual vars (used for local dev when DATABASE_URL is absent)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=task_tracker
DB_USER=postgres
DB_PASSWORD=

# Set to your Render frontend URL in production to tighten CORS
# FRONTEND_URL=https://task-tracker-ui.onrender.com
